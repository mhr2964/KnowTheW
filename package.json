{
  "name": "knowthew",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon server/index.js",
    "start": "node server/index.js",
    "client": "npm start --prefix client",
    "build": "npm run build --prefix client",
    "heroku-postbuild": "npm install --include=dev --prefix client && npm run build --prefix client",
    "seed": "node scripts/seed-distributions.js",
    "seed:fingerprints": "node scripts/seed-fingerprints.js",
    "lint": "eslint server/ test/ && npm run lint --prefix client",
    "test": "node --test \"test/**/*.test.js\"",
    "check": "npm run lint && npm test",
    "install-all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "mongodb": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "nodemon": "^3.0.0"
  }
}
